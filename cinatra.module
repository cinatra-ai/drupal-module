<?php

declare(strict_types=1);

/**
 * @file
 * Cinatra — embeds the Cinatra AI editing widget on Drupal node pages.
 */

use Drupal\Component\Utility\Html;
use Drupal\Core\Render\Markup;
use Drupal\Core\Routing\RouteMatchInterface;
use Drupal\Core\Url;
use Drupal\node\NodeInterface;

/**
 * Plugin↔core wire-contract version. Cinatra rejects unknown versions with an
 * admin-visible error. See the cinatra repo: contracts/wp-drupal-assistant/.
 *
 * v2 drops the browser apiKey: the widget exchanges a short-lived token via the
 * same-origin cinatra.token broker route instead. The bundled widget JS also
 * negotiates capabilities at boot and falls back to v1 against older instances.
 */
const CINATRA_CONTRACT_VERSION = 'v2';

/**
 * Implements hook_help().
 */
function cinatra_help(string $route_name, RouteMatchInterface $route_match): array|string {
  switch ($route_name) {
    case 'help.page.cinatra':
      // A render array so each translated string is escaped independently (no
      // manual concatenation of translated markup). The settings link is a
      // generated :url placeholder, so the URL is the only interpolated value
      // and t() handles the escaping.
      $settings_url = Url::fromRoute('cinatra.settings_form')->toString();
      return [
        'about_heading' => [
          '#type' => 'html_tag',
          '#tag' => 'h3',
          '#value' => t('About'),
        ],
        'about' => [
          '#type' => 'html_tag',
          '#tag' => 'p',
          '#value' => t('The Cinatra module embeds the Cinatra AI assistant on node pages so editors can draft and revise content in context. The assistant widget is shipped locally with the module; your Cinatra instance is used as a versioned data API. The long-lived integration credential is held server-side and exchanged for short-lived streaming tokens, so it never reaches the browser.'),
        ],
        'uses_heading' => [
          '#type' => 'html_tag',
          '#tag' => 'h3',
          '#value' => t('Uses'),
        ],
        'configure' => [
          '#type' => 'html_tag',
          '#tag' => 'p',
          '#value' => t('Configure the Cinatra instance URL, credential, and connection at <a href=":url">Configuration → Web services → Cinatra</a>.', [':url' => $settings_url]),
        ],
        'permission' => [
          '#type' => 'html_tag',
          '#tag' => 'p',
          '#value' => t('Grant the "Use the Cinatra AI assistant" permission to the roles that should see the assistant. The widget can read page context and propose content edits, so grant it only to trusted editors.'),
        ],
      ];
  }
  return [];
}

/**
 * Whether the Cinatra widget surface applies to the current request.
 *
 * Gated on the explicit "use cinatra assistant" permission (NOT merely any
 * authenticated user — the widget reads page context and can propose content
 * edits), on a node canonical/edit route or the front page. Shared by
 * hook_page_attachments() and hook_page_bottom() so the real bundle and the
 * fallback chrome render on the exact same surface.
 */
function _cinatra_widget_applies(): bool {
  if (!\Drupal::currentUser()->hasPermission('use cinatra assistant')) {
    return FALSE;
  }
  /** @var RouteMatchInterface $route */
  $route = \Drupal::routeMatch();
  $route_name = $route->getRouteName();
  $is_node_route = in_array($route_name, ['entity.node.canonical', 'entity.node.edit_form'], TRUE);
  $is_front = \Drupal::service('path.matcher')->isFrontPage();
  return $is_node_route || $is_front;
}

/**
 * Implements hook_page_attachments().
 */
function cinatra_page_attachments(array &$attachments): void {
  // Whether the widget renders depends on the "use cinatra assistant"
  // permission AND on cinatra.settings, so the page response MUST vary on both
  // EVEN WHEN the widget is not shown — otherwise a user who later gains the
  // permission (or a site that is later configured) could keep getting a
  // cached no-widget page. Declare this cache metadata before any early return.
  $attachments['#cache']['contexts'][] = 'user.permissions';
  $attachments['#cache']['contexts'][] = 'route';
  $attachments['#cache']['tags'][] = 'config:cinatra.settings';

  if (!_cinatra_widget_applies()) {
    return;
  }

  $config = \Drupal::config('cinatra.settings');
  $cinatra_url = rtrim((string) $config->get('cinatra_url'), '/');
  $api_key = (string) $config->get('api_key');

  // Widget is opt-in: skip entirely only when the Cinatra URL is unset.
  if ($cinatra_url === '') {
    return;
  }

  // ALWAYS attach the fallback chrome (button + graceful "cannot connect"
  // error card) when the URL is set, so the widget surface is never silently
  // missing — mirrors the WordPress plugin. It hides itself once the real
  // bundle mounts. The fallback only needs the Cinatra URL.
  $attachments['#attached']['library'][] = 'cinatra/fallback';
  $attachments['#attached']['drupalSettings']['cinatra']['cinatraUrl'] = $cinatra_url;

  // The real bundle attaches only when the API key is also set server-side;
  // otherwise the fallback explains the misconfiguration when the button is
  // clicked. The long-lived api_key is read here only to decide whether the
  // integration is configured — it is NEVER placed into drupalSettings.
  if ($api_key === '') {
    return;
  }

  // Node-specific settings — only populated on node routes.
  $node_id = '';
  $node_bundle = '';
  $node_status = '';
  /** @var RouteMatchInterface $route */
  $route = \Drupal::routeMatch();
  if (in_array($route->getRouteName(), ['entity.node.canonical', 'entity.node.edit_form'], TRUE)) {
    /** @var NodeInterface|NULL $node */
    $node = $route->getParameter('node');
    if ($node instanceof NodeInterface) {
      $node_id = (string) $node->id();
      $node_bundle = $node->bundle();
      $node_status = $node->isPublished() ? 'published' : 'draft';
    }
  }

  // Same-origin broker route the browser POSTs to for a short-lived token, plus
  // the CSRF token that route requires. The long-lived key stays server-side.
  $token_endpoint = Url::fromRoute('cinatra.token')->toString();
  $csrf_token = \Drupal::csrfToken()->get('cinatra/token');

  $attachments['#attached']['library'][] = 'cinatra/bundle';
  // NOTE: no 'apiKey'. The browser receives only short-lived tokens minted by
  // the cinatra.token broker route from the server-side credential.
  $attachments['#attached']['drupalSettings']['cinatra'] = [
    'contractVersion' => CINATRA_CONTRACT_VERSION,
    'cinatraUrl'      => $cinatra_url,
    'tokenEndpoint'   => $token_endpoint,
    'csrfToken'       => $csrf_token,
    'nodeId'          => $node_id,
    'nodeBundle'      => $node_bundle,
    'nodeStatus'      => $node_status,
    'instanceId'      => (string) $config->get('instance_id'),
    // The widget's "Widget administration" link points at THIS site's local
    // settings form, not a path on the Cinatra origin.
    'drupalAdminUrl'  => Url::fromRoute('cinatra.settings_form')->toString(),
  ];
  // The CSRF token is per-session; keep it out of shared render caches.
  $attachments['#cache']['contexts'][] = 'session';
}

/**
 * Implements hook_page_bottom().
 *
 * Injects the widget mount point (#cinatra-root) so the bundle.js IIFE can
 * attach its Shadow DOM, plus the fallback button + error card. Rendered
 * whenever the Cinatra URL is set (even without an API key) so a misconfigured
 * or unreachable Cinatra surfaces a graceful error instead of a missing widget.
 */
function cinatra_page_bottom(array &$page_bottom): void {
  if (!_cinatra_widget_applies()) {
    return;
  }
  $cinatra_url = rtrim((string) \Drupal::config('cinatra.settings')->get('cinatra_url'), '/');
  if ($cinatra_url === '') {
    return;
  }

  // User-facing strings are translatable. They are embedded into the chrome
  // markup below; each one is HTML-escaped at the point of interpolation
  // (Html::escape() over the rendered TranslatableMarkup) so no translated
  // string is concatenated raw into Markup::create(). The strings appear in
  // text content and in attribute values — HTML escaping is correct for both.
  $assistant_label = Html::escape((string) t('Cinatra AI Assistant'));
  $unavailable = Html::escape((string) t('Cinatra is unavailable'));
  $close = Html::escape((string) t('Close'));
  $cannot_connect = Html::escape((string) t('Could not connect to your Cinatra instance.'));

  // Brand logo color (#7a2e3a) matches the WordPress fallback + canonical mark.
  $html = '<div id="cinatra-root"></div>'
    . '<button id="cw-fallback-btn" title="' . $assistant_label . '" aria-label="' . $assistant_label . '">'
    . '<svg width="22" height="14" viewBox="0 0 512 320" fill="none" xmlns="http://www.w3.org/2000/svg">'
    . '<path d="M72 214 C 72 200 96 190 130 188 C 168 186 196 200 256 210 C 316 220 358 214 400 200 C 426 192 440 196 440 208 C 440 222 420 234 388 242 C 340 254 288 256 256 256 C 202 256 132 248 100 238 C 80 232 72 224 72 214 Z" fill="#7a2e3a"/>'
    . '<path d="M146 188 C 150 130 176 86 212 72 C 226 66 240 64 252 64 C 262 64 270 70 268 80 L 264 100 C 272 88 288 82 300 82 C 332 82 356 118 362 188 Z" fill="#7a2e3a"/>'
    . '</svg>'
    . '</button>'
    . '<div id="cw-fallback-error">'
    . '<div class="cw-fe-header">'
    . '<p class="cw-fe-title">' . $unavailable . '</p>'
    . '<button class="cw-fe-close" id="cw-fe-close" aria-label="' . $close . '">&times;</button>'
    . '</div>'
    . '<p class="cw-fe-msg" id="cw-fe-msg">' . $cannot_connect . '</p>'
    . '</div>';

  $page_bottom['cinatra_root'] = [
    '#markup' => Markup::create($html),
    '#cache' => [
      'contexts' => ['user.permissions', 'route'],
      'tags' => ['config:cinatra.settings'],
    ],
  ];
}
