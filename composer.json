{
    "name": "drupal/cinatra",
    "description": "Embeds the Cinatra AI assistant on Drupal node pages.",
    "type": "drupal-module",
    "license": "GPL-2.0-or-later",
    "homepage": "https://www.drupal.org/project/cinatra",
    "support": {
        "issues": "https://www.drupal.org/project/issues/cinatra",
        "source": "https://git.drupalcode.org/project/cinatra"
    },
    "require": {
        "php": ">=8.1",
        "drupal/core": "^10.3 || ^11"
    },
    "require-dev": {
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
        "drupal/coder": "^8.3.18 || ^9",
        "mglaman/phpstan-drupal": "^1.2 || ^2",
        "phpstan/extension-installer": "^1.3",
        "phpstan/phpstan": "^1.11 || ^2",
        "phpstan/phpstan-deprecation-rules": "^1.2 || ^2"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "phpstan/extension-installer": true,
            "drupal/core-composer-scaffold": false
        }
    },
    "scripts": {
        "phpcs": "phpcs",
        "phpcbf": "phpcbf",
        "phpstan": "phpstan analyse"
    }
}
